# Copy to .env and adjust. See src/config/configuration.ts for full docs.

# HTTP port (master process)
PORT=3001

# Number of cluster worker processes (parallel jobs)
WORKERS_COUNT=16

# HEAD request timeout (milliseconds)
HTTP_TIMEOUT_MS=10000

# Max concurrent HEAD requests within a single job
MAX_CONCURRENT_URLS=5

# Artificial delay after HEAD before saving result: random 0..N seconds
URL_DELAY_MAX_SECONDS=10
